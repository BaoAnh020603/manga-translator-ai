{
    "manifest_version": 3,
    "name": "Manga Translator AI",
    "version": "1.1.0",
    "description": "Dịch truyện tranh Manga trên web sang tiếng Việt real-time (Glassmorphism UX)",
    "permissions": [
        "activeTab",
        "scripting",
        "storage"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_title": "Cấu hình Manga Translator"
    },
    "content_scripts": [
        {
            "matches": [
                "*://weebcentral.com/*"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_idle"
        }
    ]
}